# App
NEXT_PUBLIC_APP_NAME=Acoru Business Platform Baseline

# Application database access precedence:
# 1. DATABASE_URL_DIRECT
# 2. DATABASE_URL
# 3. NEON_DATABASE_URL
DATABASE_URL=
DATABASE_URL_DIRECT=
NEON_DATABASE_URL=

# Migration runner precedence:
# 1. MIGRATION_DATABASE_URL
# 2. DATABASE_URL_DIRECT
# 3. DATABASE_URL
# 4. NEON_DATABASE_URL
# For predictable local verification, point the app runtime and migration runtime
# at the same database unless you intentionally need separate targets.
MIGRATION_DATABASE_URL=
